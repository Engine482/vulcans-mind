# Vulcan’s Mind environment example. Copy to .env for local development. Never commit real .env files.
NODE_ENV=development
PORT=3000
APP_VERSION=0.1.0
LOG_LEVEL=debug
DATABASE_URL=postgresql://user:password@localhost:5432/vulcans_mind
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MAIN_MODEL=gpt-5-mini
OPENAI_FALLBACK_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT_MS=30000
RAG_TOP_K=8
RAG_MAX_CONTEXT_CHUNKS=5
RAG_MAX_CONTEXT_CHARS=16000
RAG_MAX_CHUNKS_PER_SOURCE=2
RAG_MIN_SIMILARITY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://motornyi.com
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=600
MAX_MESSAGE_LENGTH=1500
